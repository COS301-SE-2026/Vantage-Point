{
  "name": "Vantage Point",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-node:18",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  },

  "forwardPorts": [8000, 3000, 5432],
  "postCreateCommand": "bash .devcontainer/post-create.sh"
}
