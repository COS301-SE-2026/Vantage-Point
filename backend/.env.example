DATABASE_URL=postgresql+asyncpg://riot_user:riot_password@db:5432/riot_db
# Required for linking Riot IDs — create at https://developer.riotgames.com/
RIOT_API_KEY=your_riot_api_key_here
JWT_SECRET=change-me-to-a-long-random-string
SEED_DEV_PASSWORD=choose-a-dev-only-password
TEST_USER_PASSWORD=choose-a-test-only-password
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Cognito variables
AWS_REGION=<region>
COGNITO_USER_POOL_ID=<cognito_user_pool_id>
COGNITO_CLIENT_ID=<cognito_client_pool_id>
COGNITO_CLIENT_SECRET=<aws_client_secret_string>
DEBUG=<True/False>
