name: Sync Docs Folder to GitHub Wiki

on:
  push:
    branches:
      - main
    paths:
      - '.github/docs/**'

permissions:
  contents: write

jobs:
  sync-wiki:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Codebase
        uses: actions/checkout@v4

      - name: Sync to GitHub Wiki
        uses: Andrew-Chen-Wang/github-wiki-action@v4
        with:
          path: .github/docs
          token: ${{ secrets.GITHUB_TOKEN }}
